# ---------------------------------------------------------------------------
# Data Agent Backend — Environment Configuration
# Copy this file to `.env` and fill in the real values.
# ---------------------------------------------------------------------------

# --- Server ---
PORT=8080
# Comma-separated list of allowed CORS origins (use * for all in dev)
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# Supabase / Postgres
# ---------------------------------------------------------------------------
# Supabase gives you connection strings under: Project Settings -> Database.
#
# IMPORTANT (locked-in strategy):
#   - LangGraph PostgresSaver runs DDL + prepared statements. It MUST use a
#     DIRECT (session-mode) connection on port 5432 — NOT the transaction
#     pooler on 6543 (that breaks prepared statements).
#   - Prisma runtime queries use the POOLED connection (6543) with
#     ?pgbouncer=true, and migrations use the DIRECT connection (5432).
#   - Always append ?sslmode=require.
# ---------------------------------------------------------------------------

# Prisma runtime (pooled, transaction mode, port 6543)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Prisma migrations (direct, session mode, port 5432)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# LangGraph checkpointer (direct, session mode, port 5432)
CHECKPOINT_DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# ---------------------------------------------------------------------------
# OpenRouter (LLM)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY="sk-or-v1-..."
# Optional overrides
DATA_AGENT_MODEL="deepseek/deepseek-v3.2"
OPENROUTER_APP_URL="https://your-app.com"
OPENROUTER_APP_NAME="Data Agent"

# ---------------------------------------------------------------------------
# E2B (code-interpreter sandbox)
# ---------------------------------------------------------------------------
E2B_API_KEY="e2b_..."
# Sandbox lifetime in seconds (default 3600 = 1 hour)
DATA_AGENT_SANDBOX_TIMEOUT=3600
