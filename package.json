{
  "name": "data-agent-backend",
  "version": "1.0.0",
  "private": true,
  "description": "LangGraph.js ReAct data-analyst agent with E2B sandbox, OpenRouter LLM, and Supabase-backed persistence.",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "postinstall": "node scripts/postinstall.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@e2b/code-interpreter": "^1.5.1",
    "@langchain/core": "^0.3.66",
    "@langchain/langgraph": "^0.4.9",
    "@langchain/langgraph-checkpoint-postgres": "^0.1.0",
    "@langchain/langgraph-checkpoint-sqlite": "^0.2.1",
    "@langchain/openai": "^0.6.9",
    "@prisma/client": "^6.13.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.0",
    "prisma": "^6.13.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
